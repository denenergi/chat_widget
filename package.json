{
  "name": "my-widget",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^5.15.1",
    "@testing-library/react": "^11.2.7",
    "@testing-library/user-event": "^12.8.3",
    "axios": "^1.9.0",
    "dayjs": "^1.10.7",
    "emoji-picker-react": "^3.4.12",
    "emoji-picker-textfield": "^0.2.1",
    "flag-icons": "^6.2.0",
    "sass": "^1.77.0",
    "react": "^17.0.2",
    "react-addons-css-transition-group": "^15.6.2",
    "react-app-rewire-disable-chunks": "^0.0.1",
    "react-dom": "^17.0.2",
    "react-dropzone": "^14.2.2",
    "react-frame-component": "^5.2.0",
    "react-scripts": "4.0.3",
    "react-textarea-autosize": "^8.3.3",
    "react-textarea-emoji": "^1.0.21",
    "react-transition-group": "^4.4.5",
    "react-use-websocket": "^2.9.1",
    "use-sound": "^4.0.1",
    "web-vitals": "^1.1.2"
  },
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-app-rewired start",
    "build": "cross-env CI=false NODE_OPTIONS=--openssl-legacy-provider react-app-rewired build",
    "test": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-app-rewired test",
    "eject": "react-scripts eject",
    "build:bundle": "webpack --config config-overrides.js",
    "build:widget": "parcel build src/index.js --no-source-maps -d widget && cp build/static/css/*.css widget/index.css"
