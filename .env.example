// GIF picker (gif-picker-react). Provider: giphy | klipy
REACT_APP_GIF_PROVIDER=giphy
REACT_APP_GIPHY_API_KEY=your_giphy_api_key

// GitHub Pages: add REACT_APP_GIPHY_API_KEY as repository Secret
// (Settings → Secrets and variables → Actions → New repository secret)

