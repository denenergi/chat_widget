# GIF picker (gif-picker-react). Provider: giphy | klipy
# Default key is embedded in src/utils/gifProvider.js; override here if needed.
REACT_APP_GIF_PROVIDER=giphy
REACT_APP_GIPHY_API_KEY=your_giphy_api_key

# npm start: .env.development (prod by default)
# GitHub Pages CI: .github/workflows/github-pages.yml + .env.github-pages

# --- PROD (local default) ---
REACT_APP_SOCKET_URL=wss://app.jedidesk.com/wss
REACT_APP_BASE_DOMAIN_URL=https://widget.jedidesk.com
REACT_APP_JD_DOMAIN_URL=https://app.jedidesk.com/
REACT_APP_JD_STATUS=prod

# --- DEV (swap in .env.development if needed) ---
# REACT_APP_SOCKET_URL=wss://app-jedidesk.boto.kyiv.ua/wss
# REACT_APP_BASE_DOMAIN_URL=https://app-jedidesk-widget.boto.kyiv.ua
# REACT_APP_JD_DOMAIN_URL=https://app-jedidesk.boto.kyiv.ua/
# REACT_APP_JD_STATUS=dev
